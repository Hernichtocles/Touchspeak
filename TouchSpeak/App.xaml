<Application x:Class="TouchSpeak.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#FFF2F4F8"/>
        <SolidColorBrush x:Key="KeyBackground" Color="#FFE6EAF2"/>
        <SolidColorBrush x:Key="KeySpecialBackground" Color="#FFD4DAE6"/>
        <SolidColorBrush x:Key="AccentBackground" Color="#FF4C8BF5"/>
        <SolidColorBrush x:Key="TextForeground" Color="#FF1E2230"/>
        <SolidColorBrush x:Key="HighlightBackground" Color="#FFFFE08A"/>
        <SolidColorBrush x:Key="HighlightForeground" Color="#FF1E2230"/>

        <!-- Kachel-Farben für die Vorlesen-Befehlsseite (blau = bearbeiten/navigieren, rot = sprechen) -->
        <SolidColorBrush x:Key="TileBlue" Color="#FF2F6FB0"/>
        <SolidColorBrush x:Key="TileRed" Color="#FFC0453F"/>
        <SolidColorBrush x:Key="TileActive" Color="#FFFFC107"/>
    </Application.Resources>
</Application>
