<Window x:Class="TouchSpeak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:TouchSpeak.Controls"
        Title="TouchSpeak &#x2013; Kommunikationshilfe"
        Height="900" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextForeground}">

    <Window.Resources>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
            <Setter Property="Background" Value="{StaticResource KeySpecialBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BigNavButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="MinHeight" Value="64"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>
    </Window.Resources>

    <TabControl x:Name="Tabs" Background="{StaticResource AppBackground}"
                BorderThickness="0" Margin="8"
                SelectionChanged="Tabs_SelectionChanged">

        <!-- ===================== WRITING TAB ===================== -->
        <TabItem Header="  Schreiben  " FontSize="18">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Style="{StaticResource ToolButton}" Click="New_Click" Content="&#x1F4C4;  Neu"/>
                    <Button Style="{StaticResource ToolButton}" Click="Open_Click" Content="&#x1F4C2;  Öffnen"/>
                    <Button Style="{StaticResource ToolButton}" Click="Save_Click" Content="&#x1F4BE;  Exportieren"/>
                    <Button Style="{StaticResource ToolButton}" Click="ToggleLayout_Click"
                            x:Name="LayoutButton" Content="&#x2328;  Tastatur: QWERTZ"/>
                    <Button Style="{StaticResource ToolButton}" Click="Speak_Click" Content="&#x1F50A;  Zum Vorlesen"/>
                </WrapPanel>

                <Border Grid.Row="1" Background="{StaticResource PanelBackground}" CornerRadius="10" Padding="4">
                    <RichTextBox x:Name="Editor" FontSize="22" Background="Transparent"
                                 Foreground="{StaticResource TextForeground}"
                                 BorderThickness="0" Padding="10"
                                 SpellCheck.IsEnabled="False"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsTab="True"
                                 InputMethod.IsInputMethodEnabled="False"/>
                </Border>

                <UniformGrid Grid.Row="2" x:Name="SuggestionRow" Rows="1" Columns="5" Margin="0,6">
                    <Button x:Name="Sug0" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                    <Button x:Name="Sug1" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                    <Button x:Name="Sug2" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                    <Button x:Name="Sug3" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                    <Button x:Name="Sug4" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                </UniformGrid>

                <ctrl:TouchKeyboard Grid.Row="3" x:Name="Keyboard"/>
            </Grid>
        </TabItem>

        <!-- ===================== READING TAB ===================== -->
        <TabItem Header="  Vorlesen  " FontSize="18">
            <Grid Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBackground}"
                        CornerRadius="10" Padding="6" Margin="0,0,8,0">
                    <ListBox x:Name="UnitsList" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextForeground}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="UnitsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                           FontSize="22" Padding="10" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" CornerRadius="8"
                                                    Background="Transparent" Padding="2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{StaticResource HighlightBackground}"/>
                                                    <Setter Property="TextElement.Foreground"
                                                            Value="{StaticResource HighlightForeground}"/>
                                                    <Setter Property="TextElement.FontWeight" Value="Bold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="StatusText" FontSize="18" Margin="4,2,4,8" Text="Satz 0 / 0"/>

                    <TextBlock Text="Modus" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <StackPanel Orientation="Horizontal" Margin="4,0,4,8">
                        <RadioButton x:Name="ModeSentence" Content="Satz" IsChecked="True"
                                     FontSize="16" Margin="0,0,16,0" Foreground="{StaticResource TextForeground}"
                                     Checked="Mode_Changed"/>
                        <RadioButton x:Name="ModeParagraph" Content="Abschnitt"
                                     FontSize="16" Foreground="{StaticResource TextForeground}"
                                     Checked="Mode_Changed"/>
                    </StackPanel>

                    <Button Style="{StaticResource BigNavButton}" Click="Prev_Click"
                            Content="&#x25C0;  Zurück" HorizontalAlignment="Stretch"/>
                    <Button Style="{StaticResource BigNavButton}" Click="Next_Click"
                            Content="Weiter  &#x25B6;" HorizontalAlignment="Stretch"/>

                    <Separator Margin="4,10"/>

                    <Button Style="{StaticResource ToolButton}" Click="ReplaySpeak_Click"
                            Content="&#x1F50A;  Erneut vorlesen" HorizontalAlignment="Stretch"/>
                    <Button Style="{StaticResource ToolButton}" Click="Pause_Click"
                            Content="&#x23F8;  Pause" HorizontalAlignment="Stretch"/>
                    <Button Style="{StaticResource ToolButton}" Click="Resume_Click"
                            Content="&#x25B6;  Fortsetzen" HorizontalAlignment="Stretch"/>
                    <Button Style="{StaticResource ToolButton}" Click="StopSpeak_Click"
                            Content="&#x23F9;  Stopp" HorizontalAlignment="Stretch"/>

                    <Separator Margin="4,10"/>

                    <TextBlock Text="Sprache" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <StackPanel Orientation="Horizontal" Margin="4,0,4,8">
                        <RadioButton x:Name="LangGerman" Content="Deutsch" IsChecked="True"
                                     FontSize="16" Margin="0,0,16,0" Foreground="{StaticResource TextForeground}"
                                     Checked="Lang_Changed"/>
                        <RadioButton x:Name="LangEnglish" Content="English"
                                     FontSize="16" Foreground="{StaticResource TextForeground}"
                                     Checked="Lang_Changed"/>
                    </StackPanel>

                    <TextBlock Text="Deutsche Stimme" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <ComboBox x:Name="GermanVoiceBox" Margin="4,0,4,8" FontSize="14"
                              SelectionChanged="Voice_Changed"/>

                    <TextBlock Text="Englische Stimme" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <ComboBox x:Name="EnglishVoiceBox" Margin="4,0,4,8" FontSize="14"
                              SelectionChanged="Voice_Changed"/>

                    <TextBlock Text="Geschwindigkeit" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <Slider x:Name="RateSlider" Minimum="0.5" Maximum="3.0" Value="1.0"
                            TickFrequency="0.1" Margin="4,0,4,8" ValueChanged="Rate_Changed"/>

                    <TextBlock Text="Lautstärke" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <Slider x:Name="VolumeSlider" Minimum="0.0" Maximum="1.0" Value="1.0"
                            TickFrequency="0.1" Margin="4,0,4,8" ValueChanged="Volume_Changed"/>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
