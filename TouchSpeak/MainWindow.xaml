<Window x:Class="TouchSpeak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:TouchSpeak.Controls"
        Title="TouchSpeak &#x2013; Kommunikationshilfe"
        Height="900" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextForeground}">

    <Window.Resources>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
            <Setter Property="Background" Value="{StaticResource KeySpecialBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BigNavButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="MinHeight" Value="64"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Befehlskachel (Symbol + Beschriftung) für die Vorlesen-Seite. -->
        <Style x:Key="Tile" TargetType="Button">
            <Setter Property="MinHeight" Value="92"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource TileBlue}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="on">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource TileActive}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileRed" TargetType="Button" BasedOn="{StaticResource Tile}">
            <Setter Property="Background" Value="{StaticResource TileRed}"/>
        </Style>

        <!-- Symbol- und Textzeilen innerhalb einer Kachel. -->
        <Style x:Key="TileGlyph" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="TileLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
    <TabControl x:Name="Tabs" Background="{StaticResource AppBackground}"
                BorderThickness="0" Margin="8"
                SelectionChanged="Tabs_SelectionChanged">

        <!-- ===================== WRITING TAB ===================== -->
        <TabItem Header="  Schreiben  " FontSize="18">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Style="{StaticResource ToolButton}" Click="New_Click" Content="&#x1F4C4;  Neu"/>
                    <Button Style="{StaticResource ToolButton}" Click="Open_Click" Content="&#x1F4C2;  Öffnen"/>
                    <Button Style="{StaticResource ToolButton}" Click="Save_Click" Content="&#x1F4BE;  Exportieren"/>
                    <Button Style="{StaticResource ToolButton}" Click="ToggleLayout_Click"
                            x:Name="LayoutButton" Content="&#x2328;  Tastatur: QWERTZ"/>
                    <Button Style="{StaticResource ToolButton}" Click="Speak_Click" Content="&#x1F50A;  Zum Vorlesen"/>
                </WrapPanel>

                <Border Grid.Row="1" x:Name="WritingEditorHost" Background="{StaticResource PanelBackground}" CornerRadius="10" Padding="4">
                    <RichTextBox x:Name="Editor" FontSize="22" Background="Transparent"
                                 Foreground="{StaticResource TextForeground}"
                                 BorderThickness="0" Padding="10"
                                 SpellCheck.IsEnabled="False"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsTab="True"
                                 InputMethod.IsInputMethodEnabled="False"/>
                </Border>

                <UniformGrid Grid.Row="2" x:Name="SuggestionRow" Rows="1" Columns="5" Margin="0,6">
                    <Button x:Name="Sug0" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                    <Button x:Name="Sug1" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                    <Button x:Name="Sug2" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                    <Button x:Name="Sug3" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                    <Button x:Name="Sug4" Style="{StaticResource ToolButton}" Click="Suggestion_Click" Visibility="Hidden"/>
                </UniformGrid>

                <ctrl:TouchKeyboard Grid.Row="3" x:Name="Keyboard"/>
            </Grid>
        </TabItem>

        <!-- ===================== READING TAB ===================== -->
        <TabItem x:Name="ReadingTab" Header="  Vorlesen  " FontSize="18">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Textbereich; der Editor wird hierher verschoben, sobald der Reiter aktiv ist. -->
                <Border Grid.Row="0" x:Name="ReadingEditorHost"
                        Background="{StaticResource PanelBackground}"
                        CornerRadius="10" Padding="4" Margin="0,0,0,8"/>

                <StackPanel Grid.Row="1">
                    <!-- Bearbeiten & Navigieren (blau) -->
                    <UniformGrid Columns="4">
                        <Button Style="{StaticResource Tile}" Click="Copy_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x1F4CB;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Kopieren"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="Paste_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x1F4CC;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Einfügen"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="Undo_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x21B6;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Löschen Rückgängig"/></StackPanel>
                        </Button>
                        <Button x:Name="SelectModeButton" Style="{StaticResource Tile}" Click="ToggleSelect_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x2750;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Text Auswählen"/></StackPanel>
                        </Button>

                        <Button Style="{StaticResource Tile}" Click="Left_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x2190;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Links"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="Right_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x2192;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Rechts"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="Up_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x2191;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Rauf"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="Down_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x2193;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Runter"/></StackPanel>
                        </Button>

                        <Button Style="{StaticResource Tile}" Click="PrevWord_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x23EA;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Vorheriges Wort"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="NextWord_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x23E9;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Nächstes Wort"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="DocStart_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x21E4;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Textanfang"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="DocEnd_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x21E5;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Textende"/></StackPanel>
                        </Button>

                        <Button Style="{StaticResource Tile}" Click="PrevSentence_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x23EE;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Vorheriger Satz"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="NextSentence_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x23ED;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Nächster Satz"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="LineStart_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x21A4;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Zeilenanfang"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource Tile}" Click="LineEnd_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x21A6;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Zeilenende"/></StackPanel>
                        </Button>
                    </UniformGrid>

                    <!-- Sprechen (rot) -->
                    <UniformGrid Columns="3" Margin="0,4,0,0">
                        <Button Style="{StaticResource TileRed}" Click="SpeakParagraph_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x1F5E3;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Absatz Sprechen"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource TileRed}" Click="SpeakSentence_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x1F4AC;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Satz Sprechen"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource TileRed}" Click="SpeakWord_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x1F524;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Wort Sprechen"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource TileRed}" Click="SpeakAll_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x1F50A;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Alles Sprechen"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource TileRed}" Click="SpeakSelection_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x1F5EF;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Auswahl Sprechen"/></StackPanel>
                        </Button>
                        <Button Style="{StaticResource TileRed}" Click="StopSpeak_Click">
                            <StackPanel><TextBlock Style="{StaticResource TileGlyph}" Text="&#x23F9;"/>
                                <TextBlock Style="{StaticResource TileLabel}" Text="Sprechen Beenden"/></StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- ===================== SETTINGS TAB ===================== -->
        <TabItem Header="  Einstellungen  " FontSize="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10" MaxWidth="520" HorizontalAlignment="Left">
                    <TextBlock Text="Sprache" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <StackPanel Orientation="Horizontal" Margin="4,0,4,8">
                        <RadioButton x:Name="LangGerman" Content="Deutsch" IsChecked="True"
                                     FontSize="16" Margin="0,0,16,0" Foreground="{StaticResource TextForeground}"
                                     Checked="Lang_Changed"/>
                        <RadioButton x:Name="LangEnglish" Content="English"
                                     FontSize="16" Foreground="{StaticResource TextForeground}"
                                     Checked="Lang_Changed"/>
                    </StackPanel>

                    <TextBlock Text="Deutsche Stimme" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <ComboBox x:Name="GermanVoiceBox" Margin="4,0,4,8" FontSize="14"
                              SelectionChanged="Voice_Changed"/>

                    <TextBlock Text="Englische Stimme" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <ComboBox x:Name="EnglishVoiceBox" Margin="4,0,4,8" FontSize="14"
                              SelectionChanged="Voice_Changed"/>

                    <TextBlock Text="Geschwindigkeit" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <Slider x:Name="RateSlider" Minimum="0.5" Maximum="3.0" Value="1.0"
                            TickFrequency="0.1" Margin="4,0,4,8" ValueChanged="Rate_Changed"/>

                    <TextBlock Text="Lautstärke" FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <Slider x:Name="VolumeSlider" Minimum="0.0" Maximum="1.0" Value="1.0"
                            TickFrequency="0.1" Margin="4,0,4,8" ValueChanged="Volume_Changed"/>

                    <Separator Margin="4,10"/>

                    <TextBlock Text="Kopfsteuerung (Verweil-Klick)" FontSize="14"
                               Margin="4,4,4,2" Opacity="0.8"/>
                    <CheckBox x:Name="DwellEnabledBox" Content="Aktiviert" FontSize="16"
                              Margin="4,2,4,6" Foreground="{StaticResource TextForeground}"
                              Checked="Dwell_Changed" Unchecked="Dwell_Changed"/>
                    <TextBlock x:Name="DwellTimeLabel" Text="Verweilzeit: 1,2 s"
                               FontSize="14" Margin="4,4,4,2" Opacity="0.8"/>
                    <StackPanel Orientation="Horizontal" Margin="4,0,4,8">
                        <Button Style="{StaticResource ToolButton}" Click="DwellMinus_Click"
                                Content="&#x2212;" MinWidth="56" FontSize="22"/>
                        <Slider x:Name="DwellSlider" Width="150" VerticalAlignment="Center"
                                Minimum="0.4" Maximum="3.0" Value="1.2" TickFrequency="0.1"
                                Margin="6,0" ValueChanged="DwellTime_Changed"/>
                        <Button Style="{StaticResource ToolButton}" Click="DwellPlus_Click"
                                Content="&#x002B;" MinWidth="56" FontSize="22"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>

        <!-- Overlay für den Verweil-Klick-Fortschrittsring (Kopfsteuerung).
             Liegt über allem und lässt Maus-/Kopfmaus-Eingaben durch. -->
        <Canvas x:Name="DwellOverlay" IsHitTestVisible="False"/>
    </Grid>
</Window>
